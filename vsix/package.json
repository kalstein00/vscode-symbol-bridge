{
  "name": "vscode-symbol-bridge",
  "displayName": "VS Code Symbol Bridge",
  "description": "Expose VS Code symbol provider results over local IPC for external tools.",
  "version": "0.1.0",
  "publisher": "kalstein",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscodeSymbolBridge.showHealth",
        "title": "VS Code Symbol Bridge: Show Health"
      }
    ],
    "configuration": {
      "title": "VS Code Symbol Bridge",
      "properties": {
        "vscodeSymbolBridge.enableDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose logging for the local IPC bridge."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "npm run build && node --test test/*.test.js",
    "test:integration": "npm run build && node test/integration/runTest.js",
    "watch": "tsc -w -p .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@types/node": "^22.15.18",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3",
    "@vscode/vsce": "^3.6.2"
  }
}
